# ── Database ──────────────────────────────────────────────
POSTGRES_USER=btagent
POSTGRES_PASSWORD=btagent_dev_password
POSTGRES_DB=btagent
BTAGENT_DATABASE_URL=postgresql+asyncpg://btagent:btagent_dev_password@postgres:5432/btagent

# ── Redis ─────────────────────────────────────────────────
BTAGENT_REDIS_URL=redis://redis:6379

# ── MinIO (S3-compatible evidence storage) ────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
BTAGENT_S3_ENDPOINT=http://minio:9000
BTAGENT_S3_ACCESS_KEY=minioadmin
BTAGENT_S3_SECRET_KEY=minioadmin

# ── Auth ──────────────────────────────────────────────────
BTAGENT_JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32

# ── LLM Providers ────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
AZURE_API_KEY=
AZURE_API_BASE=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
OLLAMA_HOST=http://ollama:11434

# ── App ───────────────────────────────────────────────────
BTAGENT_ENV=dev
BTAGENT_LOG_LEVEL=info
BTAGENT_MOCK_CONNECTORS=true

# ── Observability (optional) ─────────────────────────────
BTAGENT_OTEL_ENABLED=false
BTAGENT_LANGFUSE_ENABLED=false

# ── Slack (optional) ─────────────────────────────────────
BTAGENT_SLACK_BOT_TOKEN=
BTAGENT_SLACK_CHANNEL=
