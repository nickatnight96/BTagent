# BTagent backend — multi-stage build
#
# Supply chain: base image is pinned via build-arg so prod builds can lock to
# a specific digest without editing the file. Default is the minor-version
# tag, which still floats on patch releases. To fully lock, set
# ``BASE_IMAGE_DIGEST`` in CI to the output of:
#
#     docker pull python:3.12-slim-bookworm
#     docker inspect --format='{{index .RepoDigests 0}}' python:3.12-slim-bookworm
#
# and pass it as ``--build-arg BASE_IMAGE_DIGEST=sha256:...``.
ARG BASE_IMAGE=python:3.12-slim-bookworm
ARG BASE_IMAGE_DIGEST=

# Stage 1: Build
FROM ${BASE_IMAGE}${BASE_IMAGE_DIGEST:+@${BASE_IMAGE_DIGEST}} AS builder

WORKDIR /app
RUN pip install --no-cache-dir uv

# Install the four workspace packages editable, in dependency order:
#   shared -> engine -> agents -> backend
# This mirrors .github/workflows/ci.yml. ``engine`` must precede ``agents``
# because ``btagent-engine`` is a runtime dep of ``btagent-agents``, and the
# backend imports both ``btagent_agents`` (task_manager, report_service,
# playbook_service, scheduler.jobs) and ``btagent_engine`` (ws adapter,
# models_workflow) at runtime — so all four must be present or the container
# crashes on first import.
#
# Each package's source is copied before its install so the editable install
# resolves against the local tree (not PyPI, where these don't exist).

# shared (no internal deps)
COPY shared/pyproject.toml shared/
COPY shared/btagent_shared/ shared/btagent_shared/
RUN cd shared && uv pip install --system -e .

# engine (depends on shared) — pulls in pyyaml etc.
COPY engine/pyproject.toml engine/
COPY engine/btagent_engine/ engine/btagent_engine/
RUN cd engine && uv pip install --system -e .

# agents (depends on shared + engine) — pulls in the heavy runtime deps:
# langgraph, litellm, langchain-*, pysigma*.
COPY agents/pyproject.toml agents/
COPY agents/btagent_agents/ agents/btagent_agents/
RUN cd agents && uv pip install --system -e .

# backend (depends on shared) — FastAPI app, migrations, scheduler.
COPY backend/pyproject.toml backend/
COPY backend/btagent_backend/ backend/btagent_backend/
COPY backend/alembic.ini backend/
COPY backend/migrations/ backend/migrations/
RUN cd backend && uv pip install --system -e .

# Stage 2: Production
FROM ${BASE_IMAGE}${BASE_IMAGE_DIGEST:+@${BASE_IMAGE_DIGEST}}

# Security: non-root user
RUN useradd --create-home --shell /bin/bash --uid 1000 btagent
WORKDIR /app

# Copy installed packages from builder
COPY --from=builder /usr/local/lib/python3.12/site-packages/ /usr/local/lib/python3.12/site-packages/
COPY --from=builder /usr/local/bin/ /usr/local/bin/
COPY --from=builder /app/ /app/

# Set ownership
RUN chown -R btagent:btagent /app

USER btagent

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=10s --retries=3 \
    CMD python -c "import httpx; r = httpx.get('http://localhost:8000/health'); r.raise_for_status()"

CMD ["uvicorn", "btagent_backend.main:app", "--host", "0.0.0.0", "--port", "8000"]
