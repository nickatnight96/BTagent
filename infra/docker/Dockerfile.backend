# BTagent backend — multi-stage build
# Stage 1: Build
FROM python:3.12-slim-bookworm AS builder

WORKDIR /app
RUN pip install --no-cache-dir uv

# Install shared package first (cacheable layer)
COPY shared/pyproject.toml shared/
COPY shared/btagent_shared/ shared/btagent_shared/
RUN cd shared && uv pip install --system -e .

# Install backend + agents
COPY backend/pyproject.toml backend/
RUN cd backend && uv pip install --system -e .

COPY agents/pyproject.toml agents/
# Agents deps will be installed when pyproject.toml exists

# Copy source
COPY backend/btagent_backend/ backend/btagent_backend/
COPY backend/alembic.ini backend/
COPY backend/migrations/ backend/migrations/
COPY agents/btagent_agents/ agents/btagent_agents/

# Stage 2: Production
FROM python:3.12-slim-bookworm

# Security: non-root user
RUN useradd --create-home --shell /bin/bash --uid 1000 btagent
WORKDIR /app

# Copy installed packages from builder
COPY --from=builder /usr/local/lib/python3.12/site-packages/ /usr/local/lib/python3.12/site-packages/
COPY --from=builder /usr/local/bin/ /usr/local/bin/
COPY --from=builder /app/ /app/

# Set ownership
RUN chown -R btagent:btagent /app

USER btagent

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=10s --retries=3 \
    CMD python -c "import httpx; r = httpx.get('http://localhost:8000/health'); r.raise_for_status()"

CMD ["uvicorn", "btagent_backend.main:app", "--host", "0.0.0.0", "--port", "8000"]
