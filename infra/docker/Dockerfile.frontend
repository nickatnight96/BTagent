# BTagent frontend — multi-stage build
#
# Supply chain: build / runtime base images pinned via build-args so prod
# builds can lock to specific digests. Default is the minor-version tag,
# which still floats on patch releases. To fully lock:
#
#     docker pull node:20-alpine
#     docker pull nginx:1.27-alpine
#     docker inspect --format='{{index .RepoDigests 0}}' <image>
#
# and pass --build-arg NODE_DIGEST=sha256:... and --build-arg NGINX_DIGEST=...
ARG NODE_IMAGE=node:20-alpine
ARG NODE_DIGEST=
ARG NGINX_IMAGE=nginx:1.27-alpine
ARG NGINX_DIGEST=

# Stage 1: Build
FROM ${NODE_IMAGE}${NODE_DIGEST:+@${NODE_DIGEST}} AS builder

WORKDIR /app
COPY package*.json ./
# Use ``npm ci`` so the lockfile is honoured and rebuilds are deterministic.
RUN npm ci --no-audit --no-fund
COPY . .
RUN npm run build

# Stage 2: Serve with nginx
FROM ${NGINX_IMAGE}${NGINX_DIGEST:+@${NGINX_DIGEST}}

# Security: non-root
RUN adduser -D -u 1000 btagent && \
    chown -R btagent:btagent /var/cache/nginx /var/log/nginx /etc/nginx/conf.d && \
    touch /var/run/nginx.pid && chown btagent:btagent /var/run/nginx.pid

COPY --from=builder /app/dist /usr/share/nginx/html

# SPA routing: fallback to index.html
RUN echo 'server { \
    listen 80; \
    root /usr/share/nginx/html; \
    index index.html; \
    location / { \
        try_files $uri $uri/ /index.html; \
    } \
}' > /etc/nginx/conf.d/default.conf

USER btagent

EXPOSE 80
