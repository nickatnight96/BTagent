# BTagent frontend — multi-stage build
#
# Supply chain: build / runtime base images pinned via build-args so prod
# builds can lock to specific digests. Default is the minor-version tag,
# which still floats on patch releases. To fully lock:
#
#     docker pull node:20-alpine
#     docker pull nginx:1.27-alpine
#     docker inspect --format='{{index .RepoDigests 0}}' <image>
#
# and pass --build-arg NODE_DIGEST=sha256:... and --build-arg NGINX_DIGEST=...
ARG NODE_IMAGE=node:20-alpine
ARG NODE_DIGEST=
ARG NGINX_IMAGE=nginx:1.27-alpine
ARG NGINX_DIGEST=

# Stage 1: Build
FROM ${NODE_IMAGE}${NODE_DIGEST:+@${NODE_DIGEST}} AS builder

WORKDIR /app
COPY package*.json ./
# Use ``npm ci`` so the lockfile is honoured and rebuilds are deterministic.
RUN npm ci --no-audit --no-fund
COPY . .
RUN npm run build

# Stage 2: Serve with nginx
FROM ${NGINX_IMAGE}${NGINX_DIGEST:+@${NGINX_DIGEST}}

# Security: non-root
RUN adduser -D -u 1000 btagent && \
    chown -R btagent:btagent /var/cache/nginx /var/log/nginx /etc/nginx/conf.d && \
    touch /var/run/nginx.pid && chown btagent:btagent /var/run/nginx.pid

COPY --from=builder /app/dist /usr/share/nginx/html

# Hardened SPA server config — security headers are emitted by DEFAULT so the
# frontend image carries the same posture as the cluster ingress
# (``infra/nginx/nginx.conf``) and the backend middleware, even when served
# directly without the ingress in front (B7, #141). The build context is
# ``frontend/`` so the canonical reference copy at ``infra/nginx/frontend.conf``
# cannot be COPY'd here — keep the two in sync. Header values are aligned with
# the Playwright ``@nginx`` specs (X-Frame-Options DENY, nosniff, HSTS,
# CSP with script-src minus 'unsafe-inline' and a frame-ancestors directive).
RUN cat > /etc/nginx/conf.d/default.conf <<'NGINX_CONF'
server {
    listen 80;
    server_name _;

    root /usr/share/nginx/html;
    index index.html;

    add_header X-Frame-Options DENY always;
    add_header X-Content-Type-Options nosniff always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy strict-origin-when-cross-origin always;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header Content-Security-Policy "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob:; connect-src 'self' ws: wss:; frame-ancestors 'none'; base-uri 'self'; object-src 'none'; form-action 'self';" always;

    location / {
        try_files $uri $uri/ /index.html;
    }
}
NGINX_CONF

USER btagent

EXPOSE 80
